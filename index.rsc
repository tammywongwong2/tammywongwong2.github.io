 \n\nAI has broken that cycle.\n\nWith the same \"Made in America\" and White House backing like $INTC:\n\nDon't overthink things with Micron.  x.com/aleabitoreddit…\n239\n99\n100\n1.5K\n433K","source":"browser_visible","url":"https://x.com/aleabitoreddit/status/2066791570569916832"}],"topDownContext":{"alignment":"Unknown","chains":[]}},{"symbol":"GLW","mention_count":1,"first_mention":"2026-07-13T00:45:13.000Z","latest_mention":"2026-07-13T00:45:13.000Z","mentions_24h":0,"tweets_24h":0,"prices":[{"date":"2025-02-28","open":48.72999954223633,"high":50.2599983215332,"low":48.31999969482422,"close":50.150001525878906,"volume":8560300},{"date":"2025-03-03","open":50.470001220703125,"high":50.599998474121094,"low":47.95000076293945,"close":48.25,"volume":4810800},{"date":"2025-03-04","open":47.25,"high":47.43000030517578,"low":45.689998626708984,"close":46.4900016784668,"volume":9970500},{"date":"2025-03-05","open":46.869998931884766,"high":47.36000061035156,"low":46.38999938964844,"close":47.040000915527344,"volume":5721800},{"date":"2025-03-06","open":46.2400016784668,"high":46.9900016784668,"low":45.40999984741211,"close":45.5099983215332,"volume":5394000},{"date":"2025-03-07","open":45.400001525878906,"high":45.95000076293945,"low":44.099998474121094,"close":45.93000030517578,"volume":6412900},{"date":"2025-03-10","open":44.66999816894531,"high":45.400001525878906,"low":44.27000045776367,"close":45.0099983215332,"volume":5428200},{"date":"2025-03-11","open":44.810001373291016,"high":45.709999084472656,"low":44.33000183105469,"close":44.90999984741211,"volume":6771700},{"date":"2025-03-12","open":45.900001525878906,"high":46.25,"low":44.880001068115234,"close":45.400001525878906,"volume":6324700},{"date":"2025-03-13","open":45.540000915527344,"high":45.970001220703125,"low":45.0099983215332,"close":45.599998474121094,"volume":5620600},{"date":"2025-03-14","open":46.189998626708984,"high":47.08000183105469,"low":45.7599983215332,"close":46.75,"volume":7619300},{"date