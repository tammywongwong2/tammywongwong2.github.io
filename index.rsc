d":null,"plannedMaxLossUsd":null,"targets":{"oneR":466.13,"twoR":523.65,"threeR":581.17,"partialExitAllocation":"unknown"},"monitoring":{"asOf":"2026-07-20","dailyCloseOnly":true,"ma20":355.32,"lowerLows":[330.2,351.08,351.09]},"stageMaturity":{"status":"unknown","baseCount":null,"evidence":"No verified early/late-stage evidence supplied."},"sellIntoWeakness":{"courseUse":"Early Stage 2: allow normal pullbacks and sell when weakness is actually observed.","signals":[{"status":"fail","label":"Close below 20MA","evidence":"Latest close remains above 20MA.","value":false},{"status":"fail","label":"Three lower lows","evidence":"The latest three local lows are not descending.","value":false},{"status":"pass","label":"Initial stop / support breach","evidence":"Latest daily low reached the model stop.","value":null},{"status":"unknown","label":"Price and volume deterioration","evidence":"The lesson gives no fixed threshold; review the displayed OHLCV evidence manually.","value":null},{"status":"unknown","label":"Earnings risk","evidence":"Verified earnings date unavailable.","value":null}]},"sellIntoStrength":{"courseUse":"Late-stage market or stock: consider realizing gains into strength and resistance.","levels":{"oneR":466.13,"twoR":523.65,"threeR":581.17,"chartResistance":"unknown"},"climaxSignals":[{"status":"unknown","label":"Correction volume exceeds every post-breakout day","evidence":"No completed model breakout history.","value":null},{"status":"unknown","label":"Unusually high volume without matching price progress","evidence":"No verified event/chart judgement supplied.","value":null},{"status":"unknown","label":"Longest daily candle since breakout","evidence":"No completed model breakout history.","value":null}],"positiveNewsNegativeReaction":{"status":"unknown","label":"Positive news with negative price action","evidence":"No verified news-reaction evidence supplied.","value":null}},"notes":["Technical stop is wider than 10%; this model entry is not feasible and no position size is suggested.","Verified earnings date unavailable; earnings risk remains Unknown."]},"mentions":[{"mentioned_at":"2026-06-17T15:24:06.000Z","text":"Serenity @aleabitoreddit · 22h $AEHR receives follow up production order from major Silicon Photonics Customer for wafer level burn in systems. Now up 11.29% today to $116. Only 2 months ago it was in the $30's, good times. Quote Serenity @aleabitoreddit · Apr 2 $AEHR looks extremely promising at ~$1.1B MC. Aehr is starting to remind me of an early $TER, mixed with pre-earnings $AAOI. If we look at the timeline and speculated customers: Feb 11th: Sonoma production win for Hyperscaler's AI ASIC processors. (likely $GOOGL, $AMZN, 114 146 1.2K 409K","source":"browser_visible","url":"https://x.com/aleabitoreddit/status/2067267047781015579"},{"mentioned_at":"2026-06-16T07:28:51.000Z","text":"Serenity\n@aleabitoreddit\n·\n7h\nFun throwback to random ideas back in 2025.\n\nBack then, \n$AAOI\n was $2B MC, \n$LITE\n was a $26B MC, \n$AXTI\n was $500M\n\nNow:\n- AAOI is $15.37B\n- Lumentum is $74.47B\n- AXT is $7.24B\n\nWas working off less information back then, given it was an early theme. \n\nObviously nuances with ASIC\nShow more\nQuote\nSerenity\n@aleabitoreddit\n·\nDec 22, 2025\nReplying to @manukafirth\n\"Late\". \n\n$LITE is a $26B MC in the center of every future $GOOGL TPU deployment, $NVDA/ $AMZN / other GPU/ASICs. \n\n8-12% BOM share of every Google TPU v7. This is like saying $NVDA was \"late\" when price it was a $1T MC.\n\nBut if you want want another player, $AAOI. \n\n$MSFT is\n187\n53\n933\n291K","source":"browser_visible","url":"https://x.com/aleabitoreddit/status/2066785056031670657"}],"topDownContext":{"alignment":"Unknown","chains":[]}},{"symbol":"ASML","mention_count":2,"first_mention":"2026-06-19T02:22:27.000Z","latest_mention":"2026-06-21T03:32:21.000Z","mentions_24h":0,"tweets_24h":0,"prices":[{"date":"2025-02-28","open":706.8200073242188,"high":713.5,"low":697.510009765625,"close":